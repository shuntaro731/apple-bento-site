---
import { Flag } from "lucide-astro";
import figmaIcon from "../../assets/icons/figma.svg";
import desalaboImage from "../../assets/images/desalabo.png";
import vFesImage from "../../assets/images/v-fes.png";
import BentoGrid from "../BentoGrid.astro";
import AboutCard from "../cards/AboutCard.astro";
import BrandCard from "../cards/BrandCard.astro";
import WorksCard from "../cards/WorksCard.astro";

const figmaUrl = "https://www.figma.com/@shuntaro1";

const skills = [
  "UIデザイン",
  "フロントエンド",
  "Astro / Tailwind",
];
---

<BentoGrid>
  <div class="aspect-[463/219] sm:col-span-2 lg:col-start-1 lg:row-start-1 lg:aspect-auto lg:h-full">
    <AboutCard
      titleId="pr-title"
      headingTag="h2"
      showImage={false}
      prefix="What I’m"
      title="Passionate"
      suffix="About."
      description="デザインとフロントエンド開発が得意です。ユーザー体験が素晴らしいコンテンツや、いろんな業界のデザイナーの作品を見ることが好きです。このページでは、今まで作ってきた作品や好きなことを仮置きでまとめています。"
      clampDescription={false}
    />
  </div>

  <article
    class="flex aspect-square flex-col justify-between rounded-4xl bg-white p-6 sm:col-start-1 lg:col-start-1 lg:row-start-2"
    aria-labelledby="golf-title"
  >
    <span class="grid size-16 place-items-center rounded-full bg-muted-card text-black/65">
      <Flag size={26} strokeWidth={2.25} aria-hidden="true" />
    </span>

    <div>
      <h2 id="golf-title" class="text-lg font-bold leading-none text-black">
        Golf
      </h2>
      <p class="mt-4 text-xs font-bold leading-relaxed text-black/60">
        最近ベストスコアを更新して、とても嬉しいです。ドライバーが苦手なので練習中です。
      </p>
    </div>
  </article>

  <article
    class="flex aspect-square flex-col justify-center rounded-4xl bg-white p-6 sm:col-start-2 lg:col-start-2 lg:row-start-2"
    aria-labelledby="skills-title"
  >
    <h2 id="skills-title" class="text-base font-bold leading-tight text-black">
      My skills
    </h2>
    <ul class="mt-5 space-y-3 text-xs font-bold leading-none text-black/60">
      {
        skills.map((skill) => (
          <li class="flex items-center gap-2">
            <span class="size-1.5 rounded-full bg-black/35" aria-hidden="true" />
            {skill}
          </li>
        ))
      }
    </ul>
  </article>

  <div class="aspect-square lg:col-start-4 lg:row-start-1">
    <BrandCard
      url={figmaUrl}
      ariaLabel="Figmaプロフィールを開く"
      backgroundClass="bg-black"
      image={figmaIcon}
      imageAlt="Figma"
      iconClass="size-17"
    />
  </div>

  <div class="aspect-[231/465] sm:col-start-1 lg:col-start-3 lg:row-span-2 lg:row-start-1 lg:aspect-auto lg:h-full">
    <WorksCard
      title="desalabo"
      image={desalaboImage}
      imageAlt="desalaboのデザイン画面"
      url="https://www.figma.com/design/JCuVWOWpIIuqqm9PR9hQJi/desalabo?node-id=69-604&t=ktwPIXzptoyWsY0O-1"
    />
  </div>

  <div class="aspect-[231/465] sm:col-start-2 lg:col-start-4 lg:row-span-2 lg:row-start-2 lg:aspect-auto lg:h-full">
    <WorksCard
      title="V-fes"
      image={vFesImage}
      imageAlt="V-fes Appのデザイン画面"
      url="https://www.figma.com/design/coR3LlOJ6ipobMLsduN5DT/V-fes-App?node-id=1545-1079&t=OrjFR9Jt9qBH9sjR-1"
    />
  </div>
</BentoGrid>
